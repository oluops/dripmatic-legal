---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  jsonLd?: string;
}

const {
  title,
  description = 'Dripmatiq scans your wardrobe, learns your taste, and builds daily outfits you\'ll actually wear.',
  ogImage,
  ogType = 'website',
  canonicalUrl,
  jsonLd,
} = Astro.props;

const siteUrl = 'https://dripmatiq.app';
const resolvedCanonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const resolvedOgImage = ogImage || `${siteUrl}/assets/icon.png`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:site_name" content="Dripmatiq" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Dripmatiq Blog" href="/rss.xml" />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>

    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
  </head>
  <body class="bg-surface-primary text-content-primary antialiased">
    <slot />
  </body>
</html>
